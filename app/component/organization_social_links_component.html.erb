<div class="d-flex align-items-center gap-3">
  <% social_links.each do |link| %>
    <%= link_to link[:url], target: "_blank", rel: "noopener noreferrer",
                class: "org-dash-social d-inline-flex align-items-center justify-content-center text-decoration-none", title: link[:name],
                aria: { label: link[:name] } do %>
      <%= helpers.image_tag(link[:logo], class: "org-social-icon d-block", alt: "#{link[:name]} logo") %>
    <% end %>
  <% end %>
</div>