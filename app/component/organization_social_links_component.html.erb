<div class="org-dash-socials">
  <% social_links.each do |link| %>
    <%= link_to link[:url], target: "_blank", rel: "noopener noreferrer",
                class: "org-dash-social", title: link[:name],
                aria: { label: link[:name] } do %>
      <%= helpers.image_tag(link[:logo], class: "org-social-icon", alt: "#{link[:name]} logo") %>
    <% end %>
  <% end %>
</div>