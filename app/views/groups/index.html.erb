<% content_for :title, "All Groups - #{@organization.name}" %>

<div class="org-dashboard-wrapper">
  <div style="margin-bottom: 20px;">
    <%= link_to organization_path(@organization), class: "btn org-btn-outline" do %>
      <i class="fas fa-arrow-left"></i> Back to Dashboard
    <% end %>
  </div>

  <div class="org-table-container">
    <div class="org-table-header">
      <h1>All Groups</h1>
      <div class="org-table-actions">
        <% if policy(@organization).create_group? %>
          <%= link_to "+ Create Group", new_organization_group_path(@organization), class: "btn org-btn-primary", style: "padding: 8px 16px; font-size: 14px;" %>
        <% end %>
      </div>
    </div>

    <div class="org-table-wrapper">
      <table class="org-table">
        <thead>
          <tr>
            <th>Group Name</th>
            <th>Primary Mentor</th>
            <th>Members</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if @groups.empty? %>
            <tr>
              <td colspan="5" style="text-align: center; padding: 40px; color: #9ca3af; font-style: italic;">
                No groups found.
              </td>
            </tr>
          <% else %>
            <% @groups.each do |group| %>
              <tr>
                <td>
                  <div class="org-table-avatar-cell">
                    <%= link_to group.name, group_path(group), class: "org-name", style: "text-decoration: none;" %>
                  </div>
                </td>
                <td>
                  <div style="display: flex; align-items: center; gap: 8px;">
                    <% mentor = User.find_by(id: group.primary_mentor_id) %>
                    <% if mentor %>
                      <%= image_tag user_profile_picture(mentor.profile_picture), class: "org-avatar", style: "width: 24px; height: 24px;" %>
                      <%= mentor.name %>
                    <% else %>
                      Unknown
                    <% end %>
                  </div>
                </td>
                <td>
                  <span class="org-badge org-badge-member">
                    <i class="fas fa-user-graduate"></i> <%= group.group_members.count %>
                  </span>
                </td>
                <td><%= group.created_at.strftime("%b %d, %Y") %></td>
                <td style="text-align: right;">
                  <%= link_to "View", group_path(group), class: "btn org-btn-outline", style: "padding: 6px 16px; font-size: 13px;" %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @groups.present? %>
      <div class="org-table-footer">
        <div class="org-table-info">
          Showing <%= @groups.offset + 1 %>-<%= [@groups.offset + @groups.length, @groups.total_entries].min %> of <%= @groups.total_entries %> groups
        </div>
        <div class="org-pagination-wrapper">
          <%= will_paginate @groups, renderer: PaginateRenderer %>
        </div>
      </div>
    <% end %>
  </div>
</div>
