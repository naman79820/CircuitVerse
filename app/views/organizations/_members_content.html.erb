<%
  # ── Sort link helper: builds a clickable header that toggles direction ──
  cur_sort = params[:sort]
  cur_dir  = params[:direction]
  filters_active = params[:q].present? || params[:sort].present?

  sort_header = lambda do |label, col, default_dir|
    active = (cur_sort == col)
    # Next click: if already active in its default direction, flip; else use default
    next_dir =
      if active && cur_dir == default_dir
        default_dir == "asc" ? "desc" : "asc"
      elsif active
        # active but not in default dir -> go back to default
        default_dir
      else
        default_dir
      end

    # Arrow reflects the CURRENT direction of the active column
    icon =
      if active
        cur_dir == "asc" ? "fa-arrow-up" : "fa-arrow-down"
      else
        "fa-sort"
      end

    params_for_link = request.query_parameters.merge("sort" => col, "direction" => next_dir).except("page")

    link_to members_organization_path(@organization, params_for_link),
            class: "org-members-sort #{'is-active' if active}" do
      raw("#{label} <i class=\"fa #{icon} org-sort-icon\" aria-hidden=\"true\"></i>")
    end
  end
%>

<div class="org-members-content">

  <%# ── Top bar: count + add ─────────────────────────────────── %>
  <div class="org-members-topbar">
    <div>
      <h3 class="org-dash-section-title">Members</h3>
      <p class="org-members-subtitle"><%= @organization_members.total_entries %> total</p>
    </div>
    <% if policy(@organization).admin_access? %>
      <button type="button" class="org-btn-primary" onclick="openAddMemberPanel()">
        <i class="fas fa-user-plus" aria-hidden="true"></i> Add Members
      </button>
    <% end %>
  </div>

  <%# ── Toolbar: search + reset (same row) ─────────────────────── %>
  <div class="org-members-toolbar">
    <%= form_with url: members_organization_path(@organization), method: :get, local: true, id: "membersFilterForm", class: "org-members-filter-form" do |f| %>
      <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
      <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>

      <div class="org-members-search">
        <i class="fas fa-search" aria-hidden="true"></i>
        <%= f.text_field :q, value: params[:q], placeholder: "Find a member...", autocomplete: "off", id: "membersSearchInput" %>
      </div>
    <% end %>

    <% if filters_active %>
      <%= link_to members_organization_path(@organization), class: "org-members-reset" do %>
        <i class="fas fa-rotate-left" aria-hidden="true"></i> Reset
      <% end %>
    <% else %>
      <span class="org-members-reset is-disabled" aria-disabled="true">
        <i class="fas fa-rotate-left" aria-hidden="true"></i> Reset
      </span>
    <% end %>
  </div>

  <%# ── Members list ──────────────────────────────────────────── %>
  <div class="org-members-card">
    <% if @organization_members.empty? %>
      <div class="org-members-empty">
        <i class="fas fa-users-slash" aria-hidden="true"></i>
        <p>No members found.</p>
      </div>
    <% else %>
      <div class="org-members-table-head">
        <span class="col-user"><%= sort_header.call("Member", "name", "asc") %></span>
        <span class="col-role"><%= sort_header.call("Role", "role", "desc") %></span>
        <span class="col-joined"><%= sort_header.call("Joined", "joined", "desc") %></span>
        <% if policy(@organization).admin_access? %>
          <span class="col-actions"></span>
        <% end %>
      </div>

      <% @organization_members.each do |membership| %>
        <div class="org-members-row">
          <%# User %>
          <div class="col-user">
            <div class="org-member-avatar-wrapper">
              <%= image_tag user_profile_picture(membership.user.profile_picture), alt: membership.user.name, class: "org-member-avatar" %>
              <span class="org-member-role-icon" title="<%= membership.role.titleize %>">
                <% if membership.role == "admin" %>
                  <i class="fas fa-crown text-danger" aria-hidden="true"></i>
                <% elsif membership.role == "mentor" %>
                  <i class="fas fa-chalkboard-teacher text-success" aria-hidden="true"></i>
                <% else %>
                  <i class="fas fa-user text-primary" aria-hidden="true"></i>
                <% end %>
              </span>
            </div>
            <div class="org-member-identity">
              <span class="org-member-name"><%= membership.user.name %></span>
              <span class="org-member-email"><%= membership.user.email %></span>
            </div>
          </div>

          <%# Role — custom inline dropdown %>
          <div class="col-role">
            <% if policy(@organization).admin_access? && policy(membership).update? %>
              <%= form_with url: organization_organization_member_path(@organization, membership), method: :patch, local: true, class: "org-role-form" do %>
                <input type="hidden" name="organization_member[role]" value="<%= membership.role %>" class="org-role-value">
                <div class="org-role-dropdown">
                  <button type="button" class="org-role-trigger org-role-trigger--<%= membership.role %>"
                          onclick="toggleRoleMenu(this)" aria-haspopup="listbox" aria-expanded="false"
                          aria-label="Change role for <%= membership.user.name %>">
                    <span class="org-role-dot"></span>
                    <span class="org-role-trigger-label"><%= membership.role.titleize %></span>
                    <i class="fas fa-chevron-down" aria-hidden="true"></i>
                  </button>
                  <div class="org-role-menu" role="listbox">
                    <% [["admin", "Full organization access"], ["mentor", "Create & manage groups"], ["member", "Standard access"]].each do |role, desc| %>
                      <button type="button" class="org-role-option org-role-option--<%= role %> <%= "is-selected" if membership.role == role %>"
                              data-role="<%= role %>" onclick="pickRole(this)" role="option">
                        <span class="org-role-dot"></span>
                        <span class="org-role-option-text">
                          <span class="org-role-option-name"><%= role.titleize %></span>
                          <span class="org-role-option-desc"><%= desc %></span>
                        </span>
                        <i class="fas fa-check org-role-check" aria-hidden="true"></i>
                      </button>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <span class="org-badge org-badge-<%= membership.role %>"><%= membership.role.titleize %></span>
            <% end %>
          </div>

          <%# Joined %>
          <div class="col-joined">
            <%= membership.created_at.strftime("%b %d, %Y") %>
          </div>

          <%# Actions — remove %>
          <% if policy(@organization).admin_access? %>
            <div class="col-actions">
              <% if policy(membership).destroy? %>
                <%= form_with url: organization_organization_member_path(@organization, membership), method: :delete, local: true, class: "org-remove-inline-form" do %>
                  <button type="submit" class="org-remove-btn" title="Remove from organization"
                          aria-label="Remove <%= membership.user.name %> from organization"
                          onclick="return confirm('Remove <%= j membership.user.name %> from this organization?')">
                    <i class="fas fa-user-minus" aria-hidden="true"></i>
                  </button>
                <% end %>
              <% else %>
                <span class="org-actions-dash">—</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ── Footer / pagination ───────────────────────────────────── %>
  <% unless @organization_members.empty? %>
    <div class="org-members-footer">
      <div class="org-members-count">
        Showing <%= @organization_members.offset + 1 %>–<%= [@organization_members.offset + @organization_members.length, @organization_members.total_entries].min %> of <%= @organization_members.total_entries %>
      </div>
      <div class="org-index-pagination">
        <%= will_paginate @organization_members, renderer: PaginateRenderer %>
      </div>
    </div>
  <% end %>
</div>

<%# ─── Add Members slide-over (admins only) ─────────────────────── %>
<% if policy(@organization).admin_access? %>
  <div class="org-slideover-backdrop" id="addMemberBackdrop" onclick="closeAddMemberPanel()"></div>

  <aside class="org-slideover" id="addMemberPanel" role="dialog" aria-modal="true" aria-labelledby="addMemberPanelTitle">
    <div class="org-slideover-header">
      <h2 class="org-slideover-title" id="addMemberPanelTitle">
        <i class="fas fa-user-plus" aria-hidden="true"></i> Add Members
      </h2>
      <button type="button" class="org-slideover-close" onclick="closeAddMemberPanel()" aria-label="Close">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>
    </div>

    <div class="org-slideover-body">
      <%= form_with url: organization_organization_members_path(@organization), method: :post, local: true, id: "addMemberForm" do %>
        <label class="org-slideover-label" for="addMemberEmailsInput">Email addresses</label>
        <p class="org-slideover-hint">
          Separate multiple emails with commas or new lines. Only people who already have a CircuitVerse account will be added.
        </p>
        <textarea name="organization_member[emails]" id="addMemberEmailsInput"
                  class="org-slideover-textarea" rows="5"
                  placeholder="alice@example.com, bob@example.com"></textarea>

        <label class="org-slideover-label" style="margin-top: 20px;">Assign role</label>
        <div class="org-role-cards">
          <button type="button" class="org-role-card active" id="addRole-member" onclick="selectAddRole('member')">
            <i class="fas fa-user" aria-hidden="true"></i>
            <span>Member</span>
            <small>Standard access</small>
          </button>
          <button type="button" class="org-role-card" id="addRole-mentor" onclick="selectAddRole('mentor')">
            <i class="fas fa-chalkboard-teacher" aria-hidden="true"></i>
            <span>Mentor</span>
            <small>Manage groups</small>
          </button>
          <button type="button" class="org-role-card" id="addRole-admin" onclick="selectAddRole('admin')">
            <i class="fas fa-crown" aria-hidden="true"></i>
            <span>Admin</span>
            <small>Full access</small>
          </button>
        </div>

        <input type="hidden" name="organization_member[role]" id="addMemberRoleInput" value="member">

        <button type="submit" class="org-btn-primary org-slideover-submit">
          <i class="fas fa-user-plus" aria-hidden="true"></i> Add Members
        </button>
      <% end %>
    </div>
  </aside>
<% end %>

<script>
  (function () {
    // ---- Custom role dropdown ----
    window.toggleRoleMenu = function (btn) {
      var dd = btn.closest(".org-role-dropdown");
      var isOpen = dd.classList.contains("open");
      document.querySelectorAll(".org-role-dropdown.open").forEach(function (d) {
        d.classList.remove("open");
        var t = d.querySelector(".org-role-trigger");
        if (t) t.setAttribute("aria-expanded", "false");
      });
      if (!isOpen) { dd.classList.add("open"); btn.setAttribute("aria-expanded", "true"); }
    };
    window.pickRole = function (optionBtn) {
      var dd = optionBtn.closest(".org-role-dropdown");
      var form = optionBtn.closest("form");
      var role = optionBtn.dataset.role;
      var hidden = form.querySelector(".org-role-value");
      if (hidden.value === role) { dd.classList.remove("open"); return; }
      hidden.value = role;
      form.requestSubmit();
    };
    document.addEventListener("click", function (e) {
      if (!e.target.closest(".org-role-dropdown")) {
        document.querySelectorAll(".org-role-dropdown.open").forEach(function (d) { d.classList.remove("open"); });
      }
    });

    // ---- Live search (debounced auto-submit) ----
    var searchInput = document.getElementById("membersSearchInput");
    var filterForm  = document.getElementById("membersFilterForm");
    if (searchInput && filterForm) {
      var t;
      searchInput.addEventListener("input", function () {
        clearTimeout(t);
        t = setTimeout(function () { filterForm.requestSubmit(); }, 400);
      });
    }

    // ---- Add Members slide-over ----
    window.openAddMemberPanel = function () {
      var panel = document.getElementById("addMemberPanel");
      var back  = document.getElementById("addMemberBackdrop");
      if (!panel) return;
      panel.classList.add("open"); back.classList.add("open");
      document.body.style.overflow = "hidden";
      setTimeout(function () { var i = document.getElementById("addMemberEmailsInput"); if (i) i.focus(); }, 60);
    };
    window.closeAddMemberPanel = function () {
      var panel = document.getElementById("addMemberPanel");
      var back  = document.getElementById("addMemberBackdrop");
      if (!panel) return;
      panel.classList.remove("open"); back.classList.remove("open");
      document.body.style.overflow = "";
    };
    window.selectAddRole = function (role) {
      ["member", "mentor", "admin"].forEach(function (r) {
        var el = document.getElementById("addRole-" + r);
        if (el) el.classList.toggle("active", r === role);
      });
      var hidden = document.getElementById("addMemberRoleInput");
      if (hidden) hidden.value = role;
    };

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        window.closeAddMemberPanel();
        document.querySelectorAll(".org-role-dropdown.open").forEach(function (d) { d.classList.remove("open"); });
      }
    });
  })();
</script>
