<% content_for :title, "Organizations" %>

<div class="org-index-wrapper">

  <%# Flash Notice %>
  <% if notice %>
    <div class="organizations-flash-success" role="alert">
      <i class="fas fa-check-circle"></i>
      <%= notice %>
      <button class="organizations-flash-close" onclick="this.parentElement.remove()" aria-label="Close">
        <i class="fas fa-times"></i>
      </button>
    </div>
  <% end %>

  <%# Page Header %>
  <div class="org-index-header">
    <div class="org-index-header-left">
      <h1 class="org-index-title">Organizations</h1>
      <p class="org-index-subtitle">Manage and explore educational organizations on CircuitVerse.</p>
    </div>
    <div class="org-index-header-right">
      <%= link_to new_organization_path, class: "btn org-btn-primary" do %>
        <i class="fas fa-plus"></i> New Organization
      <% end %>
    </div>
  </div>

  <%# Tabs %>
  <div class="org-index-tabs">
    <%= link_to organizations_path, class: "org-index-tab #{params[:explore].blank? ? 'org-index-tab--active' : ''}" do %>
      <i class="fas fa-building"></i> My Organizations
    <% end %>
    <%= link_to organizations_path(explore: true), class: "org-index-tab #{params[:explore].present? ? 'org-index-tab--active' : ''}" do %>
      <i class="fas fa-compass"></i> Explore
    <% end %>
  </div>

  <%# Organization Cards Grid %>
  <% if @organizations.empty? %>
    <div class="org-index-empty">
      <div class="org-index-empty-icon">
        <% if params[:explore].present? %>
          <i class="fas fa-compass"></i>
        <% else %>
          <i class="fas fa-building"></i>
        <% end %>
      </div>
      <h2 class="org-index-empty-title">
        <% if params[:explore].present? %>
          No public organizations yet
        <% else %>
          You're not in any organization yet
        <% end %>
      </h2>
      <p class="org-index-empty-text">
        <% if params[:explore].present? %>
          There are no public organizations to explore right now. Check back later!
        <% else %>
          Create your own organization or ask an admin to invite you to one.
        <% end %>
      </p>
      <% if params[:explore].blank? %>
        <%= link_to new_organization_path, class: "btn org-btn-primary" do %>
          <i class="fas fa-plus"></i> Create Organization
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="org-index-grid">
      <% @organizations.each do |org| %>
        <% membership = org.organization_members.find_by(user: current_user) %>
        <%= link_to organization_path(org), class: "org-index-card" do %>
          <div class="org-index-card-header">
            <%= image_tag organization_logo(org.logo), alt: "#{org.name} logo", class: "org-index-card-logo" %>
            <% if membership %>
              <% role_label = membership.role.capitalize %>
              <span class="org-badge org-badge-<%= membership.role %>">
                <% if membership.role == 'admin' %>
                  <i class="fas fa-crown"></i>
                <% elsif membership.role == 'mentor' %>
                  <i class="fas fa-chalkboard-teacher"></i>
                <% else %>
                  <i class="fas fa-user-graduate"></i>
                <% end %>
                <%= role_label %>
              </span>
            <% elsif !org.private %>
              <span class="org-badge org-badge-public">
                <i class="fas fa-globe"></i> Public
              </span>
            <% end %>
          </div>

          <div class="org-index-card-body">
            <h2 class="org-index-card-name"><%= org.name %></h2>
            <p class="org-index-card-desc">
              <% if org.description.present? %>
                <%= truncate(org.description, length: 90, separator: ' ') %>
              <% else %>
                <span class="org-index-card-no-desc">No description provided.</span>
              <% end %>
            </p>
          </div>

          <div class="org-index-card-footer">
            <div class="org-index-card-stat">
              <i class="fas fa-users"></i>
              <%= org.organization_members.count %> <%= "member".pluralize(org.organization_members.count) %>
            </div>
            <div class="org-index-card-stat">
              <i class="fas fa-layer-group"></i>
              <%= org.groups.count %> <%= "group".pluralize(org.groups.count) %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Pagination %>
    <% if @organizations.total_pages > 1 %>
      <div class="org-index-pagination">
        <%= will_paginate @organizations, renderer: PaginateRenderer %>
      </div>
    <% end %>
  <% end %>

</div>
