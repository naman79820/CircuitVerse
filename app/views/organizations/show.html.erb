<% content_for :title, @organization.name %>

<div class="org-dashboard-wrapper">

  <%# Flash notice %>
  <% if notice %>
    <div class="organizations-flash-success" role="alert" id="organizations-flash-notice">
      <i class="fas fa-check-circle"></i>
      <%= notice %>
      <button class="organizations-flash-close" onclick="this.parentElement.remove()" aria-label="Close">
        <i class="fas fa-times"></i>
      </button>
    </div>
  <% end %>

  <%# Header Section %>
  <div class="org-dashboard-header">
    <div class="org-header-left">
      <%= image_tag organization_logo(@organization.logo), alt: "#{@organization.name} logo", class: "org-header-logo" %>
      <div class="org-header-text">
        <h1 class="org-header-title">
          <%= @organization.name %> <span class="org-header-highlight">Dashboard</span>
        </h1>
        <p class="org-header-subtitle">
          <% if @organization.description.present? %>
            <%= truncate(@organization.description, length: 160, separator: ' ') %>
          <% else %>
            Manage your organization's members, groups, and settings.
          <% end %>
        </p>
      </div>
    </div>
    
    <div class="org-header-right" style="display: flex; gap: 12px; align-items: center;">
      <% if current_user.organizations.count > 1 %>
        <%= link_to organizations_path, class: "btn org-btn-outline" do %>
          <i class="fas fa-exchange-alt"></i> Switch Organization
        <% end %>
      <% else %>
        <%= link_to organizations_path, class: "btn org-btn-outline" do %>
          <i class="fas fa-building"></i> All Organizations
        <% end %>
      <% end %>

      <% if policy(@organization).admin_access? %>
        <%= link_to edit_organization_path(@organization), class: "btn org-btn-primary" do %>
          <i class="fas fa-cog"></i> Settings
        <% end %>
      <% else %>
        <% current_membership = @organization.organization_members.find_by(user: current_user) %>
        <% if current_membership %>
          <%= link_to organization_organization_member_path(@organization, current_membership),
              method: :delete,
              data: { confirm: t("organizations.show.leave_confirm") },
              class: "btn org-btn-danger-outline" do %>
            <i class="fas fa-sign-out-alt"></i> <%= t("organizations.show.leave_btn") %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Stat Cards Row %>
  <div class="org-stats-row">
    <%# Stat 1: Total Members %>
    <div class="org-stat-card">
      <div class="org-stat-card-top">
        <div class="org-stat-icon-wrapper"><i class="fas fa-users"></i></div>
        <span class="org-stat-label">TOTAL MEMBERS</span>
      </div>
      <div class="org-stat-value"><%= @organization.organization_members.count %></div>
      <div class="org-stat-trend">
        <i class="fas fa-arrow-up"></i> Active community
      </div>
    </div>

    <%# Stat 2: Total Mentors %>
    <div class="org-stat-card">
      <div class="org-stat-card-top">
        <div class="org-stat-icon-wrapper"><i class="fas fa-chalkboard-teacher"></i></div>
        <span class="org-stat-label">TOTAL MENTORS</span>
      </div>
      <div class="org-stat-value"><%= @organization.organization_members.mentor.count + @organization.organization_members.admin.count %></div>
      <div class="org-stat-trend">
        <i class="fas fa-arrow-up"></i> Guiding students
      </div>
    </div>

    <%# Stat 3: Groups %>
    <div class="org-stat-card">
      <div class="org-stat-card-top">
        <div class="org-stat-icon-wrapper"><i class="fas fa-layer-group"></i></div>
        <span class="org-stat-label">GROUPS</span>
      </div>
      <div class="org-stat-value"><%= @organization.groups.count %></div>
      <div class="org-stat-trend">
        <i class="fas fa-arrow-up"></i> Classrooms running
      </div>
    </div>
  </div>

  <%# Main Split Grid %>
  <div class="org-main-grid">
    
    <%# Left Panel: Recent Members %>
    <div class="org-panel">
      <div class="org-panel-header">
        <h2 class="org-panel-title">Organization Members</h2>
        <% if policy(@organization).admin_access? %>
          <%= link_to "View All", organization_organization_members_path(@organization), class: "org-panel-link" %>
        <% end %>
      </div>
      
      <div class="org-members-list">
        <% if @organization.organization_members.empty? %>
          <p class="org-empty-state"><%= t("organizations.show.no_members") %></p>
        <% else %>
          <% @organization.organization_members.includes(:user).order(created_at: :desc).limit(5).each do |membership| %>
            <div class="org-member-item">
              <div class="org-member-item-left">
                <div class="org-member-avatar-wrapper">
                  <%= image_tag user_profile_picture(membership.user.profile_picture), alt: membership.user.name, class: "org-member-avatar" %>
                  <div class="org-member-role-icon" title="<%= membership.role.titleize %>">
                    <% if membership.role == 'admin' %>
                      <i class="fas fa-crown text-danger"></i>
                    <% elsif membership.role == 'mentor' %>
                      <i class="fas fa-chalkboard-teacher text-success"></i>
                    <% else %>
                      <i class="fas fa-user text-primary"></i>
                    <% end %>
                  </div>
                </div>
                <div class="org-member-info">
                  <span class="org-member-name"><strong><%= membership.user.name %></strong></span>
                  <span class="org-member-email"><%= membership.user.email %></span>
                </div>
              </div>
              <div class="org-member-item-right">
                <span class="org-badge org-badge-<%= membership.role %>">
                  <% if membership.role == 'admin' %>
                    <i class="fas fa-crown"></i>
                  <% elsif membership.role == 'mentor' %>
                    <i class="fas fa-chalkboard-teacher"></i>
                  <% else %>
                    <i class="fas fa-user"></i>
                  <% end %>
                  <%= membership.role.titleize %>
                </span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
      
      <% if @organization.organization_members.count > 5 %>
        <div class="org-panel-footer">
          <%= link_to "+ #{@organization.organization_members.count - 5} more members", organization_organization_members_path(@organization), class: "org-panel-link", style: "font-weight: 600; font-size: 14px;" %>
        </div>
      <% end %>
    </div>

    <%# Right Panel: Groups List Panel %>
    <div class="org-panel">
      <div class="org-panel-header">
        <h2 class="org-panel-title">Groups</h2>
        <div style="display: flex; gap: 16px; align-items: center;">
          <% if policy(@organization).create_group? %>
            <%= link_to "+ Create Group", new_organization_group_path(@organization), class: "org-panel-link" %>
          <% end %>
          <% if @organization.groups.present? %>
            <%= link_to "View All", organization_groups_path(@organization), class: "org-panel-link" %>
          <% end %>
        </div>
      </div>
      
      <% if @organization.groups.empty? %>
        <div class="org-empty-state">
          <p style="margin-bottom: 16px;"><%= t("organizations.show.no_groups") %></p>
          <% if policy(@organization).create_group? %>
            <%= link_to "+ Create your first group", new_organization_group_path(@organization), class: "btn org-btn-primary" %>
          <% end %>
        </div>
      <% else %>
        <div class="org-groups-grid">
          <% @organization.groups.limit(4).each do |group| %>
            <%= link_to group_path(group), class: "org-group-card" do %>
              <div class="org-group-card-top">
                <div class="org-group-icon">
                  <i class="fas fa-desktop"></i>
                </div>
                <div class="org-group-menu">
                  <i class="fas fa-ellipsis-h"></i>
                </div>
              </div>
              <div class="org-group-card-body">
                <h3 class="org-group-name"><%= group.name %></h3>
                <p class="org-group-members"><%= group.group_members.count %> members</p>
              </div>
            <% end %>
          <% end %>
        </div>
        
        <% if @organization.groups.count > 4 %>
          <div class="org-panel-footer">
            <%= link_to "+ #{@organization.groups.count - 4} more groups", organization_groups_path(@organization), class: "org-panel-link", style: "font-weight: 600; font-size: 14px;" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Bottom Banner %>
  <% if @organization.links.present? && @organization.links.any?(&:present?) %>
    <div class="org-links-section">
      <h3 class="org-links-title">Featured Links</h3>
      <div class="org-links-list">
        <% @organization.links.reject(&:blank?).each_with_index do |link, index| %>
          <%= link_to link, target: "_blank", rel: "noopener noreferrer", class: "org-link-pill" do %>
            <div class="org-link-number"><%= index + 1 %></div>
            <span class="org-link-text"><%= link %></span>
            <i class="fas fa-arrow-right org-link-arrow"></i>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
