<div class="org-dash">
  <%# Organization name %>
  <h1 class="org-dash-name"><%= @organization.name %></h1>

  <%# Tabs (shown on every tab — this is the navigation) %>
  <nav class="org-dash-tabs" aria-label="Organization sections">
    <%= link_to "Overview", overview_organization_path(@organization),
          class: "org-dash-tab #{'is-active' if @active_tab == 'overview'}" %>
    <%= link_to "Members", members_organization_path(@organization),
          class: "org-dash-tab #{'is-active' if @active_tab == 'members'}" %>
    <% if policy(@organization).admin_access? %>
      <%= link_to "Settings", settings_organization_path(@organization),
            class: "org-dash-tab #{'is-active' if @active_tab == 'settings'}" %>
    <% end %>
  </nav>

  <hr class="org-dash-divider">

  <%# Header (logo + info) — ONLY on the overview tab %>
  <% if @active_tab == "overview" %>
    <header class="org-dash-header">
      <div class="org-dash-logo">
        <% if @organization.logo.attached? %>
          <%= image_tag @organization.logo, alt: "#{@organization.name} logo" %>
        <% else %>
          <span class="org-dash-logo-fallback"><%= @organization.name.first.upcase %></span>
        <% end %>
      </div>

      <div class="org-dash-info">
        <h2 class="org-dash-info-name"><%= @organization.name %></h2>
        <% if @organization.description.present? %>
          <p class="org-dash-info-desc"><%= @organization.description %></p>
        <% end %>
        <div class="org-dash-info-meta">
          <% org_links = (@organization.respond_to?(:links) && @organization.links.is_a?(Array)) ? @organization.links.reject(&:blank?) : [] %>
          <% if org_links.any? %>
            <div class="org-dash-socials">
              <% org_links.each do |link| %>
                <% if link =~ /(?:twitter\.com|x\.com)/i %>
                  <%= link_to link, target: "_blank", rel: "noopener noreferrer",
                        class: "org-dash-social org-dash-social-x", title: link do %>
                    <svg viewBox="0 0 24 24" width="25" height="25" fill="currentColor" aria-hidden="true">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                  <% end %>
                <% else %>
                  <%= link_to link, target: "_blank", rel: "noopener noreferrer",
                        class: "org-dash-social", title: link do %>
                    <i class="org-social-icon <%= icon_for_url(link) %>" aria-hidden="true"></i>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          <% end %>
          <% if @organization.location.present? %>
            <% if org_links.any? %><span class="org-dash-meta-sep" aria-hidden="true"></span><% end %>
            <span class="org-dash-location">
              <i class="fa fa-map-marker-alt" aria-hidden="true"></i>
              <%= @organization.location %>
            </span>
          <% end %>
        </div>
      </div>
    </header>
  <% end %>

  <%# Per-tab content %>
  <%= yield :dashboard_content %>
</div>
