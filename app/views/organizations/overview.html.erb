<% content_for :title, @organization.name %>

<%= render(OrganizationDashboardShellComponent.new(organization: @organization, active_tab: "overview")) do |shell| %>
  <% shell.with_tab_content do %>

    <header class="d-flex flex-column flex-sm-row gap-4 align-items-start mb-4">
      <div class="org-dash-logo d-flex align-items-center justify-content-center flex-shrink-0 overflow-hidden rounded-4 border bg-light">
        <% if @organization.logo.attached? %>
          <%= image_tag @organization.logo, alt: t(".logo_alt", organization: @organization.name), class: "w-100 h-100 object-fit-cover" %>
        <% else %>
          <span class="org-dash-logo-fallback fw-bold"><%= @organization.name.first.upcase %></span>
        <% end %>
      </div>

      <div class="org-dash-info pt-1">
        <p class="org-dash-info-name fw-bold mb-2"><%= @organization.name %></p>
        <% if @organization.description.present? %>
          <p class="org-dash-info-desc lh-base mb-3 text-secondary"><%= @organization.description %></p>
        <% end %>
        <div class="d-flex align-items-center gap-3 flex-wrap">
          <% has_links = @organization.links.present? && @organization.links.reject(&:blank?).any? %>
          <% if has_links %>
            <%= render(OrganizationSocialLinksComponent.new(links: @organization.links)) %>
          <% end %>
          <% if @organization.location.present? %>
            <% if has_links %><span class="org-dash-meta-sep" aria-hidden="true"></span><% end %>
            <span class="org-dash-location d-inline-flex align-items-center gap-2">
              <i class="fa fa-map-marker-alt lh-1" aria-hidden="true"></i>
              <%= @organization.location %>
            </span>
          <% end %>
        </div>
      </div>
    </header>

    <section>
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="org-dash-section-title fw-semibold m-0"><%= t(".groups_heading") %></h3>
        <% if policy(@organization).admin_access? %>
          <%= link_to new_group_path(organization_id: @organization.slug), class: "org-dash-add-btn d-inline-flex align-items-center gap-1 text-decoration-none rounded-3 fw-medium text-white" do %>
            <i class="fa fa-plus" aria-hidden="true"></i> <%= t(".new_group_button") %>
          <% end %>
        <% end %>
      </div>

      <% if @groups.blank? %>
        <div class="org-dash-empty text-center rounded-4">
          <i class="fa fa-layer-group d-block mb-2 opacity-50" aria-hidden="true"></i>
          <p class="m-0 fw-medium"><%= t("organizations.show.no_groups") %></p>
        </div>
      <% else %>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
          <% @groups.each do |group| %>
            <div class="col">
              <%= link_to group_path(group), class: "org-dash-group-card d-flex flex-column justify-content-between text-decoration-none rounded-4 h-100 p-3" do %>
                <span class="org-dash-group-name fw-semibold"><%= group.name %></span>
                <span class="org-dash-group-meta d-inline-flex align-items-center gap-1">
                  <i class="fa fa-user" aria-hidden="true"></i>
                  <%= t(".member_count", count: group.group_members_count) %>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="org-index-pagination mt-4">
          <%= will_paginate @groups, param_name: "groups_page", renderer: PaginateRenderer %>
        </div>
      <% end %>
    </section>

  <% end %>
<% end %>
