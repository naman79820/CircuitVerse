<% content_for :title, "All Members - #{@organization.name}" %>

<div class="org-dashboard-wrapper">
  <div style="margin-bottom: 20px;">
    <%= link_to organization_path(@organization), class: "btn org-btn-outline" do %>
      <i class="fas fa-arrow-left"></i> Back to Dashboard
    <% end %>
  </div>

  <div class="org-table-container">
    <div class="org-table-header" style="flex-wrap: wrap; gap: 16px;">
      <h1>All Members</h1>

      <div class="dropdown org-filters-dropdown">
        <button class="org-filter-btn dropdown-toggle" type="button" id="filterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="fas fa-filter"></i> Filter &amp; Sort
        </button>
        <div class="dropdown-menu dropdown-menu-end p-3" aria-labelledby="filterDropdown" style="width: 250px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
          <%= form_with url: organization_organization_members_path(@organization), method: :get, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :role, "Filter by Role", class: "form-label fw-bold", style: "font-size: 14px;" %>
              <%= f.select :role,
                  options_for_select([['All Roles', ''], ['Admin', 'admin'], ['Mentor', 'mentor'], ['Member', 'member']], params[:role]),
                  {},
                  class: "form-select form-control", style: "font-size: 14px;" %>
            </div>

            <div class="mb-3">
              <%= f.label :sort, "Sort by", class: "form-label fw-bold", style: "font-size: 14px;" %>
              <%= f.select :sort,
                  options_for_select([['Role & Name', ''], ['Newest', 'newest'], ['Oldest', 'oldest']], params[:sort]),
                  {},
                  class: "form-select form-control", style: "font-size: 14px;" %>
            </div>

            <button type="submit" class="btn btn-primary w-100" style="font-size: 14px;">Apply</button>
          <% end %>
        </div>
      </div>

      <% if policy(@organization).admin_access? %>
        <button class="btn org-btn-primary" onclick="openAddMemberModal()" style="display:inline-flex; align-items:center; gap:8px;">
          <i class="fas fa-user-plus"></i> Add Member
        </button>
      <% end %>
    </div>

    <div class="org-table-wrapper">
      <table class="org-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Joined</th>
            <% if policy(@organization).admin_access? %>
              <th style="text-align: center;">Actions</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% if @organization_members.empty? %>
            <tr>
              <td colspan="<%= policy(@organization).admin_access? ? 5 : 4 %>" style="text-align: center; padding: 40px; color: #9ca3af; font-style: italic;">
                No members found.
              </td>
            </tr>
          <% else %>
            <% @organization_members.each do |membership| %>
              <tr>
                <td>
                  <div class="org-table-avatar-cell">
                    <div class="org-member-avatar-wrapper">
                      <%= image_tag user_profile_picture(membership.user.profile_picture), alt: membership.user.name, class: "org-member-avatar", style: "width: 32px; height: 32px;" %>
                      <div class="org-member-role-icon" title="<%= membership.role.titleize %>" style="bottom: -2px; right: -2px; width: 14px; height: 14px; font-size: 8px;">
                        <% if membership.role == 'admin' %>
                          <i class="fas fa-crown text-danger"></i>
                        <% elsif membership.role == 'mentor' %>
                          <i class="fas fa-chalkboard-teacher text-success"></i>
                        <% else %>
                          <i class="fas fa-user text-primary"></i>
                        <% end %>
                      </div>
                    </div>
                    <span class="org-name" style="margin-left: 8px;"><%= membership.user.name %></span>
                  </div>
                </td>
                <td><%= membership.user.email %></td>
                <td>
                  <span class="org-badge org-badge-<%= membership.role %>">
                    <% if membership.role == 'admin' %>
                      <i class="fas fa-crown"></i>
                    <% elsif membership.role == 'mentor' %>
                      <i class="fas fa-chalkboard-teacher"></i>
                    <% else %>
                      <i class="fas fa-user"></i>
                    <% end %>
                    <%= membership.role.titleize %>
                  </span>
                </td>
                <td><%= membership.created_at.strftime("%b %d, %Y") %></td>
                <% if policy(@organization).admin_access? %>
                  <td style="text-align: center;">
                    <% if policy(membership).update? || policy(membership).destroy? %>
                      <button class="org-manage-btn"
                              data-member-name="<%= membership.user.name %>"
                              data-member-email="<%= membership.user.email %>"
                              data-member-role="<%= membership.role %>"
                              data-member-avatar="<%= user_profile_picture(membership.user.profile_picture) %>"
                              data-update-url="<%= organization_organization_member_path(@organization, membership) %>"
                              data-destroy-url="<%= organization_organization_member_path(@organization, membership) %>"
                              data-can-update="<%= policy(membership).update? %>"
                              data-can-destroy="<%= policy(membership).destroy? %>"
                              onclick="openManageMemberModal(this)">
                        <i class="fas fa-user-cog"></i> Manage
                      </button>
                    <% else %>
                      <span style="font-size: 12px; color: #9ca3af; font-style: italic;">—</span>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="org-table-footer">
      <div class="org-table-info">
        Showing <%= @organization_members.offset + 1 %>–<%= [@organization_members.offset + @organization_members.length, @organization_members.total_entries].min %> of <%= @organization_members.total_entries %> members
      </div>
      <div class="org-pagination-wrapper">
        <%= will_paginate @organization_members, renderer: PaginateRenderer %>
      </div>
    </div>
  </div>
</div>

<%# ─── Manage Member Modal ───────────────────────────────────────── %>
<div class="org-modal-backdrop" id="manageMemberBackdrop" onclick="closeManageMemberModal()"></div>

<div class="org-modal" id="manageMemberModal" role="dialog" aria-modal="true" aria-labelledby="manageMemberModalTitle">
  <div class="org-modal-header">
    <h2 class="org-modal-title" id="manageMemberModalTitle">Manage Member</h2>
    <button class="org-modal-close" onclick="closeManageMemberModal()" aria-label="Close">
      <i class="fas fa-times"></i>
    </button>
  </div>

  <div class="org-modal-body">
    <%# Member info strip %>
    <div class="org-modal-member-info">
      <img id="modalMemberAvatar" src="" alt="" class="org-modal-avatar">
      <div>
        <div class="org-modal-member-name" id="modalMemberName"></div>
        <div class="org-modal-member-email" id="modalMemberEmail"></div>
        <div style="margin-top: 6px;" id="modalCurrentRoleBadge"></div>
      </div>
    </div>

    <%# Role picker (admin-only) %>
    <div id="modalRoleSection">
      <div class="org-modal-section-label">Change Role</div>
      <div class="org-modal-role-grid">
        <button type="button" class="org-role-btn" id="roleBtn-admin" onclick="selectRole('admin')">
          <i class="fas fa-crown"></i>
          <span>Admin</span>
          <small>Full organization access</small>
        </button>
        <button type="button" class="org-role-btn" id="roleBtn-mentor" onclick="selectRole('mentor')">
          <i class="fas fa-chalkboard-teacher"></i>
          <span>Mentor</span>
          <small>Can create &amp; manage groups</small>
        </button>
        <button type="button" class="org-role-btn" id="roleBtn-member" onclick="selectRole('member')">
          <i class="fas fa-user"></i>
          <span>Member</span>
          <small>Standard access</small>
        </button>
      </div>

      <%= form_with url: "#", method: :patch, local: true, id: "updateRoleForm" do |f| %>
        <%= hidden_field_tag "organization_member[role]", "", id: "selectedRoleInput" %>
        <button type="submit" class="btn org-btn-primary" style="margin-top: 16px; width: 100%;">
          <i class="fas fa-check"></i> Save Role
        </button>
      <% end %>
    </div>

    <div id="modalDivider" class="org-modal-divider"></div>

    <%# Remove section %>
    <div id="modalDestroySection">
      <div class="org-modal-section-label" style="color: #ff5959;">Danger Zone</div>
      <%= form_with url: "#", method: :delete, local: true, id: "destroyMemberForm",
          data: { confirm: "Are you sure you want to remove this member from the organization?" } do %>
        <button type="submit" class="btn org-btn-danger-outline" style="width: 100%;">
          <i class="fas fa-user-minus"></i> Remove from Organization
        </button>
      <% end %>
    </div>
  </div>
</div>

<script>
  function openManageMemberModal(btn) {
    var memberName   = btn.dataset.memberName;
    var memberEmail  = btn.dataset.memberEmail;
    var memberRole   = btn.dataset.memberRole;
    var memberAvatar = btn.dataset.memberAvatar;
    var updateUrl    = btn.dataset.updateUrl;
    var destroyUrl   = btn.dataset.destroyUrl;
    var canUpdate    = btn.dataset.canUpdate === "true";
    var canDestroy   = btn.dataset.canDestroy === "true";

    // Populate info
    document.getElementById("modalMemberAvatar").src = memberAvatar;
    document.getElementById("modalMemberAvatar").alt = memberName;
    document.getElementById("modalMemberName").textContent  = memberName;
    document.getElementById("modalMemberEmail").textContent = memberEmail;

    // Current role badge
    var roleIcons  = { admin: "fa-crown", mentor: "fa-chalkboard-teacher", member: "fa-user" };
    var roleColors = { admin: "org-badge-admin", mentor: "org-badge-mentor", member: "org-badge-member" };
    document.getElementById("modalCurrentRoleBadge").innerHTML =
      '<span class="org-badge ' + roleColors[memberRole] + '">' +
      '<i class="fas ' + roleIcons[memberRole] + '"></i> ' +
      memberRole.charAt(0).toUpperCase() + memberRole.slice(1) + '</span>';

    // Role buttons — highlight current
    ["admin", "mentor", "member"].forEach(function(r) {
      document.getElementById("roleBtn-" + r).classList.toggle("active", r === memberRole);
    });
    document.getElementById("selectedRoleInput").value = memberRole;

    // Wire forms
    document.getElementById("updateRoleForm").action  = updateUrl;
    document.getElementById("destroyMemberForm").action = destroyUrl;

    // Show/hide sections
    document.getElementById("modalRoleSection").style.display    = canUpdate  ? "block" : "none";
    document.getElementById("modalDivider").style.display        = (canUpdate && canDestroy) ? "block" : "none";
    document.getElementById("modalDestroySection").style.display = canDestroy ? "block" : "none";

    // Open
    document.getElementById("manageMemberModal").classList.add("open");
    document.getElementById("manageMemberBackdrop").classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeManageMemberModal() {
    document.getElementById("manageMemberModal").classList.remove("open");
    document.getElementById("manageMemberBackdrop").classList.remove("open");
    document.body.style.overflow = "";
  }

  function selectRole(role) {
    ["admin", "mentor", "member"].forEach(function(r) {
      document.getElementById("roleBtn-" + r).classList.toggle("active", r === role);
    });
    document.getElementById("selectedRoleInput").value = role;
  }

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") closeManageMemberModal();
  });
</script>

<%# ─── Add Member Modal ──────────────────────────────────────────── %>
<div class="org-modal-backdrop" id="addMemberBackdrop" onclick="closeAddMemberModal()"></div>

<div class="org-modal" id="addMemberModal" role="dialog" aria-modal="true" aria-labelledby="addMemberModalTitle">
  <div class="org-modal-header">
    <h2 class="org-modal-title" id="addMemberModalTitle">
      <i class="fas fa-user-plus" style="margin-right:8px; color:#10b981;"></i>Add Member
    </h2>
    <button class="org-modal-close" onclick="closeAddMemberModal()" aria-label="Close">
      <i class="fas fa-times"></i>
    </button>
  </div>

  <div class="org-modal-body">
    <div class="org-modal-section-label">Emails</div>
    <p style="font-size:13px; color:#6b7280; margin-bottom: 12px;">
      Enter one or more email addresses separated by commas or new lines.
      Only users who already have a CircuitVerse account will be added.
    </p>

    <%= form_with url: organization_organization_members_path(@organization), method: :post, local: true, id: "addMemberForm" do |f| %>
      <textarea
        name="organization_member[emails]"
        id="addMemberEmailsInput"
        class="organizations-text-input"
        rows="5"
        placeholder="alice@example.com, bob@example.com"
        style="width:100%; resize:vertical; font-size:14px;"
      ></textarea>

      <div class="org-modal-section-label" style="margin-top: 20px;">Role</div>
      <div class="org-modal-role-grid" style="margin-bottom: 16px;">
        <button type="button" class="org-role-btn active" id="addRoleBtn-member" onclick="selectAddRole('member')">
          <i class="fas fa-user"></i>
          <span>Member</span>
          <small>Standard access</small>
        </button>
        <button type="button" class="org-role-btn" id="addRoleBtn-mentor" onclick="selectAddRole('mentor')">
          <i class="fas fa-chalkboard-teacher"></i>
          <span>Mentor</span>
          <small>Can manage groups</small>
        </button>
        <button type="button" class="org-role-btn" id="addRoleBtn-admin" onclick="selectAddRole('admin')">
          <i class="fas fa-crown"></i>
          <span>Admin</span>
          <small>Full access</small>
        </button>
      </div>

      <input type="hidden" name="organization_member[role]" id="addMemberRoleInput" value="member">

      <button type="submit" class="btn org-btn-primary" style="width:100%;">
        <i class="fas fa-user-plus"></i> Add Member(s)
      </button>
    <% end %>
  </div>
</div>

<script>
  function openAddMemberModal() {
    document.getElementById("addMemberEmailsInput").value = "";
    selectAddRole("member");
    document.getElementById("addMemberModal").classList.add("open");
    document.getElementById("addMemberBackdrop").classList.add("open");
    document.body.style.overflow = "hidden";
    setTimeout(function() { document.getElementById("addMemberEmailsInput").focus(); }, 50);
  }

  function closeAddMemberModal() {
    document.getElementById("addMemberModal").classList.remove("open");
    document.getElementById("addMemberBackdrop").classList.remove("open");
    document.body.style.overflow = "";
  }

  function selectAddRole(role) {
    ["member", "mentor", "admin"].forEach(function(r) {
      document.getElementById("addRoleBtn-" + r).classList.toggle("active", r === role);
    });
    document.getElementById("addMemberRoleInput").value = role;
  }
</script>
